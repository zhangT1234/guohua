<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.newgrand.mapper.PFormPurchaseOrderDMapper">

    <select id="updateStatusList" resultType="java.lang.Integer">
        update P_FORM_PURCHASE_ORDER_D set  where phid in
        <foreach collection="list" index="index" item="item"
                 separator="," open="(" close=")">
            #{item,jdbcType=LONG}
        </foreach>
    </select>
</mapper>